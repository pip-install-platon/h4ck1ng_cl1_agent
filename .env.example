# Скопируй в .env в каталоге запуска или экспортируй в shell.

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash

# PENTEST_SCOPE_TARGET=
# PENTEST_SCOPE_POLICY=

# ktools MCP (Docker по умолчанию при COPILOT_KALI_MCP_AUTO=1)
# COPILOT_KALI_MCP_AUTO=1
# COPILOT_KALI_MCP_DOCKER_IMAGE=kali-tools-mcp-server:latest
# COPILOT_KALI_TOOLS_MCP_CMD=

# security-framework MCP (LLM tools); см. README и zer0-kr/security-framework-mcp
# COPILOT_SECURITY_FRAMEWORK_LLM=1
# COPILOT_SECURITY_FRAMEWORK_MCP_CMD=["security-framework-mcp"]
# COPILOT_SECURITY_MCP_AUTO=0
# Дефолтный набор = как в security_tools_openrouter.DEFAULT_SECURITY_TOOLS_WHITELIST (можно раскомментировать как есть)
# COPILOT_SECURITY_TOOLS_ALLOWLIST=cross_reference,generate_checklist,get_asvs,get_attack_technique,get_cwe,get_framework_section,get_masvs,get_top10,get_wstg,map_finding,search_cve,search_framework,search_owasp
# COPILOT_SECURITY_MCP_BOOT_TIMEOUT=120
# COPILOT_SECURITY_MCP_PING_TIMEOUT=30
# COPILOT_SECURITY_MCP_LIST_TOOLS_TIMEOUT=45
# COPILOT_SECURITY_MCP_TOOL_TIMEOUT=
# COPILOT_SECURITY_TOOLS_ONE_SHOT=0

# Общий лимит раундов tool_calls (приоритет над COPILOT_KALI_TOOLS_LLM_MAX_ROUNDS)
# COPILOT_LLM_TOOL_ROUNDS=16

# Методология в промпте: full | minimal (или авто: короче при security-LLM)
# COPILOT_TACTICS_PROMPT_MODE=

# Методология: свой файл вместо knowledge/tactics_stub.md
# COPILOT_KNOWLEDGE_PATH=

# Сводка скана в промпт (nmap -oG, stdout, фрагмент отчёта)
# COPILOT_SCOPE_FACTS_FILE=./scan-summary.txt
# COPILOT_SCOPE_FACTS_MAX_BYTES=524288
# COPILOT_SCOPE_FACTS_PROMPT_CHARS=12000

# Совместимость LLM API (убрать Referer/X-Title): 1 для многих не-OpenRouter шлюзов
# COPILOT_OPENAI_COMPAT_MODE=0
# Доп. заголовки JSON (Azure и др.)
# COPILOT_LLM_EXTRA_HEADERS_JSON=
