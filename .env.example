# Скопируй в .env в каталоге запуска или экспортируй в shell.

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash
# Отдельная модель для digest/retry вывода команд (необязательно; без неё всё на OPENROUTER_MODEL)
# COPILOT_COMMAND_MODEL=

# PENTEST_SCOPE_TARGET=
# PENTEST_SCOPE_POLICY=

# ktools MCP (Docker по умолчанию при COPILOT_KALI_MCP_AUTO=1)
# COPILOT_KALI_MCP_AUTO=1
# COPILOT_KALI_MCP_DOCKER_IMAGE=kali-tools-mcp-server:latest
# COPILOT_KALI_TOOLS_MCP_CMD=

# security-framework MCP (LLM tools); см. README и zer0-kr/security-framework-mcp
# COPILOT_SECURITY_FRAMEWORK_LLM=1
# COPILOT_SECURITY_FRAMEWORK_MCP_CMD=["security-framework-mcp"]
# COPILOT_SECURITY_MCP_AUTO=0
# Дефолтный набор = как в pentest_copilot.mcp.security_tools_openrouter.DEFAULT_SECURITY_TOOLS_WHITELIST (можно раскомментировать как есть)
# COPILOT_SECURITY_TOOLS_ALLOWLIST=cross_reference,generate_checklist,get_asvs,get_attack_technique,get_cwe,get_framework_section,get_masvs,get_top10,get_wstg,map_finding,search_cve,search_framework,search_owasp
# COPILOT_SECURITY_MCP_BOOT_TIMEOUT=120
# COPILOT_SECURITY_MCP_PING_TIMEOUT=30
# COPILOT_SECURITY_MCP_LIST_TOOLS_TIMEOUT=45
# COPILOT_SECURITY_MCP_TOOL_TIMEOUT=
# COPILOT_SECURITY_TOOLS_ONE_SHOT=0

# Общий лимит раундов tool_calls (приоритет над COPILOT_KALI_TOOLS_LLM_MAX_ROUNDS)
# COPILOT_LLM_TOOL_ROUNDS=16

# Методология в промпте: full | minimal (или авто: короче при security-LLM)
# COPILOT_TACTICS_PROMPT_MODE=

# Методология: свой файл вместо knowledge/tactics_stub.md
# COPILOT_KNOWLEDGE_PATH=

# Сводка скана в промпт (nmap -oG, stdout, фрагмент отчёта)
# COPILOT_SCOPE_FACTS_FILE=./scan-summary.txt
# COPILOT_SCOPE_FACTS_MAX_BYTES=524288
# COPILOT_SCOPE_FACTS_PROMPT_CHARS=12000

# Совместимость LLM API (убрать Referer/X-Title): 1 для многих не-OpenRouter шлюзов
# COPILOT_OPENAI_COMPAT_MODE=0
# Доп. заголовки JSON (Azure и др.)
# COPILOT_LLM_EXTRA_HEADERS_JSON=

# Офлайн / медленный PyPI — см. README «Частые проблемы»
# COPILOT_PREFLIGHT_SKIP_PIP_UPGRADE=1
# COPILOT_PREFLIGHT_PIP_TIMEOUT=180

# Boot-intro держать на экране минимум N сек после MCP
# COPILOT_BOOT_INTRO_MIN_SEC=1.2

# Превью стрима (stdout после команды; режим chunk)
# COPILOT_STREAM_PREVIEW_LINES=12
# COPILOT_STREAM_CHUNK_LINE_TAIL=24
# COPILOT_STREAM_CHUNK_PREVIEW_CHARS=8000
# COPILOT_STRIP_ANSI_PREVIEW=1
# «Пульс» во время стрима (спиннер + время + объём в subtitle панели)
# COPILOT_STREAM_HEARTBEAT=1
# COPILOT_STREAM_TICK_SEC=0.12
#
# Краткое резюме вывода после команды (stream/classic), нужен OPENROUTER_API_KEY и базовый URL модели
# COPILOT_POST_RUN_LLM_DIGEST=
# COPILOT_POST_RUN_LLM_DIGEST_TIMEOUT=50
# COPILOT_POST_RUN_LLM_DIGEST_MAX_CHARS=28000
# COPILOT_POST_RUN_LLM_DIGEST_MIN_CHARS=32
#
# Повтор после ошибки: объяснение + новая команда от LLM (stream/classic; trust — без второго запроса)
# COPILOT_CMD_RETRY_ON_FAIL=1
# COPILOT_CMD_RETRY_MAX=1
# COPILOT_CMD_RETRY_LLM_TIMEOUT=120
# COPILOT_CMD_RETRY_LLM_MAX_CHARS=24000
#
# Рамка вокруг строки ввода (как Cursor CLI agent)
# COPILOT_INPUT_BOX=1
# COPILOT_INPUT_BOX_TITLE=You
# Многострочный композер: Enter = отправка; Shift+Enter = новая строка (если терминал шлёт CSI); иначе Ctrl+O / F8; F9 = отправка
# COPILOT_INPUT_MULTILINE=1
